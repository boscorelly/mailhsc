# ════════════════════════════════════════════════════════════════════════════════
# MailLens — environment configuration
# Copy to .env and fill in your values before running docker compose up.
#
#   cp .env.example .env
#   chmod 600 .env          # restrict read access — contains secrets
#
# This file is read by Docker Compose at parse time, which means ALL variables
# defined here are available for label/environment substitution across ALL
# services (app + traefik). Do NOT commit .env to git.
# ════════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
# Internal port the Go app listens on (no reason to change this)
PORT=8080

# ── Domain & TLS ─────────────────────────────────────────────────────────────
# Domain used for Traefik routing rules and Let's Encrypt certificate.
# Leave "localhost" for local dev (Traefik issues a self-signed cert).
DOMAIN=localhost

# Email for Let's Encrypt expiry notifications.
TRAEFIK_ACME_EMAIL=admin@yourdomain.com

# ── ACME challenge ────────────────────────────────────────────────────────────
# Which resolver to use for TLS certificate issuance:
#   (empty)           Local dev — Traefik generates a self-signed certificate
#   letsencrypt-tls   TLS-ALPN-01 — port 443 must be reachable from internet
#   letsencrypt-dns   DNS-01      — works behind NAT, supports wildcards
#
# Leave empty for local dev (DOMAIN=localhost).
# Set to letsencrypt-tls or letsencrypt-dns for production.
ACME_RESOLVER=

# ── DNS-01 challenge credentials ─────────────────────────────────────────────
# Only required when ACME_RESOLVER=letsencrypt-dns.
# Uncomment and fill the block for your DNS provider.
# For the full provider list and required variables see traefik/traefik.yml.
#
# ── OVH ──────────────────────────────────────────────────────────────────────
# TRAEFIK_DNS_PROVIDER=ovh
# OVH_ENDPOINT=ovh-eu
# OVH_APPLICATION_KEY=
# OVH_APPLICATION_SECRET=
# OVH_CONSUMER_KEY=
#
# ── Cloudflare ────────────────────────────────────────────────────────────────
# TRAEFIK_DNS_PROVIDER=cloudflare
# CF_DNS_API_TOKEN=
#
# ── Gandi ─────────────────────────────────────────────────────────────────────
# TRAEFIK_DNS_PROVIDER=gandiv5
# GANDIV5_PERSONAL_ACCESS_TOKEN=
#
# ── Scaleway ──────────────────────────────────────────────────────────────────
# TRAEFIK_DNS_PROVIDER=scaleway
# SCALEWAY_API_TOKEN=
#
# ── Route53 (AWS) ─────────────────────────────────────────────────────────────
# TRAEFIK_DNS_PROVIDER=route53
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-1
#
# ── DigitalOcean ──────────────────────────────────────────────────────────────
# TRAEFIK_DNS_PROVIDER=digitalocean
# DO_AUTH_TOKEN=
#
# ── Namecheap ─────────────────────────────────────────────────────────────────
# TRAEFIK_DNS_PROVIDER=namecheap
# NAMECHEAP_API_USER=
# NAMECHEAP_API_KEY=
